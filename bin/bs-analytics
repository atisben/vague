#!/usr/bin/env bash
# bs-analytics — local skill usage dashboard
#
# Usage:
#   bs-analytics        # last 7 days (default)
#   bs-analytics 7d
#   bs-analytics 30d
#   bs-analytics all

set -uo pipefail

STATE_DIR="${BASTACK_HOME:-$HOME/.bastack}"
JSONL_FILE="$STATE_DIR/analytics/skill-usage.jsonl"

WINDOW="${1:-7d}"
case "$WINDOW" in
  7d)  DAYS=7;  LABEL="last 7 days" ;;
  30d) DAYS=30; LABEL="last 30 days" ;;
  all) DAYS=0;  LABEL="all time" ;;
  *)   DAYS=7;  LABEL="last 7 days" ;;
esac

if [ ! -f "$JSONL_FILE" ] || [ "$(wc -l < "$JSONL_FILE" | tr -d ' ')" = "0" ]; then
  echo "bastack usage — no data yet"
  echo "Run some skills and check back!"
  exit 0
fi

# Filter by time window
if [ "$DAYS" -gt 0 ] 2>/dev/null; then
  if date -v-1d +%Y-%m-%d >/dev/null 2>&1; then
    CUTOFF="$(date -v-${DAYS}d -u +%Y-%m-%dT%H:%M:%SZ)"
  else
    CUTOFF="$(date -u -d "$DAYS days ago" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "2000-01-01T00:00:00Z")"
  fi
  FILTERED="$(awk -F'"' -v cutoff="$CUTOFF" '
    /"ts":"/ {
      for (i=1; i<=NF; i++) {
        if ($i == "ts" && $(i+1) ~ /^:/) {
          ts = $(i+2)
          if (ts >= cutoff) { print; break }
        }
      }
    }
  ' "$JSONL_FILE")"
else
  FILTERED="$(cat "$JSONL_FILE")"
fi

[ -z "$FILTERED" ] && echo "bastack usage ($LABEL) — no runs found" && exit 0

SKILL_COUNTS="$(echo "$FILTERED" | awk -F'"' '
  /"skill":"/ {
    for (i=1; i<=NF; i++) {
      if ($i == "skill" && $(i+1) ~ /^:/) { counts[$(i+2)]++; break }
    }
  }
  END { for (s in counts) print counts[s], s }
' | sort -rn)"

TOTAL="$(echo "$FILTERED" | wc -l | tr -d ' ')"
MAX_COUNT="$(echo "$SKILL_COUNTS" | head -1 | awk '{print $1}')"
BAR_WIDTH=20

echo "bastack usage ($LABEL)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo "$SKILL_COUNTS" | while read -r COUNT SKILL; do
  BAR_LEN=$(( COUNT * BAR_WIDTH / MAX_COUNT ))
  [ "$BAR_LEN" -lt 1 ] && BAR_LEN=1
  BAR=""; i=0
  while [ "$i" -lt "$BAR_LEN" ]; do BAR="${BAR}█"; i=$(( i + 1 )); done
  printf "  /%-22s %s  %d run(s)\n" "$SKILL" "$BAR" "$COUNT"
done

echo ""
echo "Total skill runs: ${TOTAL}"
