#!/usr/bin/env bash
# bs-learnings-log — append a learning entry to the project learnings file
# Usage: bs-learnings-log '{"skill":"review","type":"pitfall","key":"n-plus-one","insight":"...","confidence":8,"source":"observed"}'
#
# Append-only JSONL. Duplicates resolved at read time (latest winner per key+type).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/bs-slug" 2>/dev/null)" || true
BASTACK_HOME="${BASTACK_HOME:-$HOME/.bastack}"
mkdir -p "$BASTACK_HOME/projects/$SLUG"

INPUT="${1:-}"
[ -z "$INPUT" ] && exit 1

# Validate JSON
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  echo "bs-learnings-log: invalid JSON, skipping" >&2
  exit 1
fi

# Inject timestamp if absent
if ! printf '%s' "$INPUT" | bun -e "
  const j = JSON.parse(await Bun.stdin.text());
  if (!j.ts) process.exit(1);
" 2>/dev/null; then
  INPUT=$(printf '%s' "$INPUT" | bun -e "
    const j = JSON.parse(await Bun.stdin.text());
    j.ts = new Date().toISOString();
    console.log(JSON.stringify(j));
  " 2>/dev/null) || exit 1
fi

echo "$INPUT" >> "$BASTACK_HOME/projects/$SLUG/learnings.jsonl"
