#!/usr/bin/env bash
# bs-slug — derive SLUG and BRANCH from git context
# Usage: eval "$(bs-slug)"  → sets $SLUG and $BRANCH
#
# Sanitized to [a-zA-Z0-9._-] only, preventing shell injection.

set -euo pipefail

RAW_SLUG=$(git remote get-url origin 2>/dev/null \
  | sed 's|.*[:/]\([^/]*/[^/]*\)\.git$|\1|;s|.*[:/]\([^/]*/[^/]*\)$|\1|' \
  | tr '/' '-') || true
RAW_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/' '-') || true

SLUG=$(printf '%s' "${RAW_SLUG:-}" | tr -cd 'a-zA-Z0-9._-')
BRANCH=$(printf '%s' "${RAW_BRANCH:-}" | tr -cd 'a-zA-Z0-9._-')

SLUG="${SLUG:-$(basename "$PWD" | tr -cd 'a-zA-Z0-9._-')}"
BRANCH="${BRANCH:-unknown}"

echo "SLUG=$SLUG"
echo "BRANCH=$BRANCH"
